generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  AGENT
  GATEKEEPER
  TREASURER
}

enum TicketType {
  NORMAL
  VIP
}

enum TicketStatus {
  IN_STOCK
  ASSIGNED
  SOLD
  SCANNED
  BANNED
  INVALID
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hashed
  role      Role     @default(AGENT)
  
  // Relations
  assignedTickets AccessCode[] @relation("AssignedAgent")


  // Finance Relations
  agentSettlements     Settlement[] @relation("AgentSettlements")
  treasurerSettlements Settlement[] @relation("TreasurerSettlements")
  recordedExpenses     Expense[]    @relation("RecordedExpenses")
  
  // Transfer Relations
  sentTransfers        TicketTransfer[] @relation("SentTransfers")
  receivedTransfers    TicketTransfer[] @relation("ReceivedTransfers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccessCode {
  id            String       @id @default(uuid())
  code          String?      @unique // Human Readable 8-char code (e.g. A7X9-B2) - Nullable until bound
  serialNumber  String?      // Physical Ticket Number (e.g. 0501)
  
  status        TicketStatus @default(IN_STOCK)
  type          TicketType   @default(NORMAL)
  
  // Assignment & CRM
  assignedToId  String?
  assignedTo    User?        @relation("AssignedAgent", fields: [assignedToId], references: [id])
  
  ownerName     String?
  ownerEmail    String?
  customerMobile String?
  paymentMode    String?     // 'CASH' | 'BANK_TRANSFER'

  paymentSettled Boolean     @default(false)
  
  settlementId  Int?
  settlement    Settlement?  @relation(fields: [settlementId], references: [id])
  
  transferId    Int?
  transfer      TicketTransfer? @relation(fields: [transferId], references: [id])
  
  scannedAt     DateTime?    // Null = Not inside yet
  votedAt       DateTime?    // Null = Has not voted yet

  vote          Vote?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum VoteCategory {
  BAND
  SOLO_SINGING
  GROUP_SINGING
  SOLO_DANCING
  GROUP_DANCING
}

model Candidate {
  id        Int          @id @default(autoincrement())
  name      String
  institute String?      // e.g. SLIIT, NIBM
  image     String?      // URL
  category  VoteCategory

  votesAsBand          Vote[] @relation("BandVotes")
  votesAsSoloSinging   Vote[] @relation("SoloSingingVotes")
  votesAsGroupSinging  Vote[] @relation("GroupSingingVotes")
  votesAsSoloDancing   Vote[] @relation("SoloDancingVotes")
  votesAsGroupDancing  Vote[] @relation("GroupDancingVotes")
}

model Vote {
  id            Int      @id @default(autoincrement())
  
  accessCodeId  String   @unique
  accessCode    AccessCode @relation(fields: [accessCodeId], references: [id])
  
  // Selections (One per category)
  bandId        Int?
  band          Candidate? @relation("BandVotes", fields: [bandId], references: [id])
  
  soloSingingId Int?
  soloSinging   Candidate? @relation("SoloSingingVotes", fields: [soloSingingId], references: [id])
  
  groupSingingId Int?
  groupSinging   Candidate? @relation("GroupSingingVotes", fields: [groupSingingId], references: [id])
  
  soloDancingId Int?
  soloDancing   Candidate? @relation("SoloDancingVotes", fields: [soloDancingId], references: [id])
  
  groupDancingId Int?
  groupDancing   Candidate? @relation("GroupDancingVotes", fields: [groupDancingId], references: [id])

  timestamp     DateTime @default(now())
}

// --- Finance & Treasurer ---

model Settlement {
  id          Int          @id @default(autoincrement())
  
  agentId     String
  agent       User         @relation("AgentSettlements", fields: [agentId], references: [id])
  
  treasurerId String?
  treasurer   User?        @relation("TreasurerSettlements", fields: [treasurerId], references: [id])

  status      String       @default("CONFIRMED") // PENDING, CONFIRMED, REJECTED
  proofImage  String?      // Logic for Bank Transfer settlement proofs

  amount      Float
  tickets     AccessCode[] // Tickets covered by this settlement

  timestamp   DateTime     @default(now())
}

model TicketTransfer {
  id          Int      @id @default(autoincrement())
  
  fromAgentId String
  fromAgent   User     @relation("SentTransfers", fields: [fromAgentId], references: [id])
  
  toAgentId   String
  toAgent     User     @relation("ReceivedTransfers", fields: [toAgentId], references: [id])
  
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, CANCELLED
  
  tickets     AccessCode[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  imageUrl    String?
  
  recordedById String
  recordedBy   User   @relation("RecordedExpenses", fields: [recordedById], references: [id])
  
  timestamp   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. ASSIGN_BATCH, MARK_SOLD, SETTLE_FINANCE
  entityId  String   // ID of the thing being affected (TicketID, UserID)
  details   String?  // JSON string or description
  
  actorId   String   // User ID who did it
  actorName String   // Snapshot of name
  
  timestamp DateTime @default(now())
}

model GlobalSettings {
  id              Int      @id @default(1) // Singleton Row
  isSystemLockdown Boolean @default(false)
  isVotingOpen    Boolean  @default(false)
  isResultsPublic Boolean  @default(false)
  
  updatedAt       DateTime @updatedAt
}
